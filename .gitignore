# Dependencies
node_modules/

# Test artifacts (videos, screenshots, reports)
test-results/
playwright-report/

# Auth sessions (cookies, tokens, storage states)
.auth/

# Root .env (bundled OAuth secrets, server config)
.env

# Instance-specific env files (may contain vault refs, org URLs)
# Keep *.example files for reference
instances/*.env

# Vault tokens (per-profile, never commit)
instances/.vault-auth.json

# Discovery cache (auto-generated, per-profile)
.cache/

# Active instance profile selector
.instance-profile

# macOS
.DS_Store

# Local AI coding assistant settings
.*laude/
*laude.md

# Editor
.vscode/
*.swp
*.swo
*~

# Build artifacts (intermediate frames, palettes)
artifacts/demo-gif/*.png
artifacts/demo-gif/*.txt
screenshots/

# OS
Thumbs.db

# Runtime
*.log
npm-debug.log*
