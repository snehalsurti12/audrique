{
  "name": "SCV Full End-to-End Suite",
  "version": 2,
  "stopOnFailure": false,
  "connectionSetId": "personal",
  "vocabulary": {
    "agentApp": "Service Console",
    "supervisorSurface": "Command Center for Service",
    "omniStatus": "Available",
    "defaultQueue": "SCV Basic Queue",
    "supportQueue": "Support Queue",
    "entryNumber": "+18775145931"
  },
  "defaults": {
    "callTrigger": {
      "mode": "connect_ccp",
      "ivrMode": "speech"
    },
    "timeouts": {
      "ringSec": 180,
      "supervisorQueueSec": 180,
      "supervisorAgentOfferSec": 180,
      "offerAfterQueueSec": 180
    }
  },
  "scenarios": [
    {
      "id": "inbound-agent-offer",
      "description": "Direct inbound call — agent accepts, VoiceCall screen pop appears.",
      "callTrigger": {
        "mode": "connect_ccp"
      },
      "steps": [
        {
          "action": "preflight"
        },
        {
          "action": "trigger_call"
        },
        {
          "action": "detect_incoming"
        },
        {
          "action": "accept_call"
        },
        {
          "action": "verify_screen_pop"
        }
      ],
      "expect": [
        {
          "type": "e2e.call_connected",
          "equals": true
        },
        {
          "type": "e2e.screen_pop_detected",
          "equals": true
        }
      ],
      "enabled": true
    },
    {
      "id": "ivr-support-queue-branch",
      "description": "DTMF 1 routes to Support Queue — supervisor verifies queue routing.",
      "allowFailure": true,
      "callTrigger": {
        "mode": "connect_ccp",
        "ivrLanguage": "en",
        "ivrMaxPromptWaitSec": 15,
        "ivrSteps": [
          { "dtmf": "1", "expect": "press 1|support", "label": "Support Queue" }
        ]
      },
      "steps": [
        {
          "action": "preflight"
        },
        {
          "action": "start_supervisor",
          "queue": "Support Queue",
          "observeAgentOffer": false,
          "checkBeforeAccept": true
        },
        {
          "action": "trigger_call"
        },
        {
          "action": "detect_incoming"
        },
        {
          "action": "accept_call"
        },
        {
          "action": "verify_screen_pop"
        }
      ],
      "expect": [
        {
          "type": "e2e.call_connected",
          "equals": true
        },
        {
          "type": "e2e.supervisor_queue_observed",
          "queue": "Support Queue"
        },
        {
          "type": "e2e.screen_pop_detected",
          "equals": true
        }
      ],
      "timeouts": {
        "supervisorPostQueueHoldSec": 4,
        "supervisorBeforeAcceptWaitMs": 7000
      }
    },
    {
      "id": "ivr-timeout-default-queue-branch",
      "description": "No DTMF — IVR timeout routes to default SCV Basic Queue.",
      "allowFailure": true,
      "callTrigger": {
        "mode": "connect_ccp",
        "ivrDigits": ""
      },
      "steps": [
        {
          "action": "preflight"
        },
        {
          "action": "start_supervisor",
          "queue": "SCV Basic Queue",
          "checkBeforeAccept": true
        },
        {
          "action": "trigger_call"
        },
        {
          "action": "detect_incoming"
        },
        {
          "action": "accept_call"
        },
        {
          "action": "verify_screen_pop"
        }
      ],
      "expect": [
        {
          "type": "e2e.call_connected",
          "equals": true
        },
        {
          "type": "e2e.supervisor_queue_observed",
          "queue": "SCV Basic Queue"
        },
        {
          "type": "e2e.screen_pop_detected",
          "equals": true
        }
      ],
      "timeouts": {
        "supervisorPostQueueHoldSec": 4
      }
    }
  ]
}
